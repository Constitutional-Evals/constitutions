{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://constitutionalevals.org/schema/anchor-set.schema.json",
  "title": "Anchor set (basis definition)",
  "type": "object",
  "required": ["basis_version", "fit_locked", "anchors"],
  "additionalProperties": false,
  "properties": {
    "basis_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "fit_locked": { "type": "boolean" },
    "latent_rank_D": { "type": ["integer", "null"] },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
